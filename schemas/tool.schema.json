{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/product-ai-registry/schemas/tool.schema.json",
  "title": "Tool Metadata",
  "type": "object",
  "required": ["id", "name", "version", "description", "entry", "runtime", "os"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "entry": { "type": "string" },
    "runtime": { "type": "string" },
    "os": {
      "type": "array",
      "items": { "type": "string" }
    },
    "install_scope": {
      "type": "string",
      "enum": ["global", "project"]
    },
    "target_path": { "type": "string" },
    "agents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "description_scope": {
      "type": "string",
      "enum": ["general", "repo-specific"]
    },
    "inputs": {
      "type": "array",
      "items": { "type": "object" }
    },
    "outputs": {
      "type": "array",
      "items": { "type": "object" }
    },
    "requires": {
      "type": "object",
      "additionalProperties": true
    },
    "permissions": {
      "type": "object",
      "additionalProperties": true
    },
    "dispatch": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
